{
  "name": "@rgrmdesign/rgrm-ds-tokens",
  "version": "0.10.0",
  "description": "Design tokens (CSS custom properties) generated from Figma variables via Style Dictionary.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RGRMdesign/rgrm-ds-tokens.git"
  },
  "homepage": "https://github.com/RGRMdesign/rgrm-ds-tokens#readme",
  "bugs": "https://github.com/RGRMdesign/rgrm-ds-tokens/issues",
  "type": "module",
  "main": "dist/tokens.css",
  "style": "dist/tokens.css",
  "exports": {
    ".": "./dist/tokens.css",
    "./tokens.css": "./dist/tokens.css",
    "./root.css": "./dist/css/root.css",
    "./dark.css": "./dist/css/theme-dark.css",
    "./brand.css": "./dist/css/theme-brand.css",
    "./components.css": "./dist/css/components.css",
    "./css/*": "./dist/css/*"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist build",
    "build": "tsx build.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run clean && pnpm run typecheck && pnpm run build",
    "release": "changeset publish"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "design-tokens",
    "style-dictionary",
    "css",
    "custom-properties",
    "figma"
  ],
  "license": "MIT",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22.13"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.1",
    "rimraf": "^6.1.3",
    "style-dictionary": "^4.4.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
